#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

runtime_dir=".edge-lm-server"
venv_python="$runtime_dir/.venv/bin/python"
marker="$runtime_dir/.deps-installed"

if [[ "${1:-}" == "clean" ]]; then
  rm -rf "$runtime_dir"
  echo "removed $runtime_dir"
  exit 0
fi

find_python() {
  if [[ -n "${EDGE_LM_PYTHON:-}" ]]; then
    printf '%s\n' "$EDGE_LM_PYTHON"
    return 0
  fi

  for candidate in python3.14 python3.13 python3.12 python3.11 python3.10 python3; do
    if command -v "$candidate" >/dev/null 2>&1; then
      "$candidate" - <<'PY' >/dev/null 2>&1 && { printf '%s\n' "$candidate"; return 0; }
import sys
raise SystemExit(0 if sys.version_info >= (3, 10) else 1)
PY
    fi
  done

  return 1
}

needs_reinstall=0
for arg in "$@"; do
  if [[ "$arg" == "--reinstall" ]]; then
    needs_reinstall=1
  fi
done

if [[ ! -x "$venv_python" ]]; then
  python_bin="$(find_python || true)"
  if [[ -z "${python_bin:-}" ]]; then
    echo "error: Python >= 3.10 was not found. Install Python, then rerun ./run." >&2
    exit 1
  fi
  mkdir -p "$runtime_dir"
  "$python_bin" -m venv "$runtime_dir/.venv"
  needs_reinstall=1
fi

if [[ ! -f "$marker" || "$needs_reinstall" == "1" ]]; then
  "$venv_python" -m pip install --upgrade pip setuptools wheel
  "$venv_python" -m pip install --upgrade \
    "git+https://github.com/TheStageAI/edge-lm.git" \
    fastapi \
    uvicorn
  printf 'ok\n' > "$marker"
fi

export PYTHONPATH="$PWD/src${PYTHONPATH:+:$PYTHONPATH}"
case "${1:-}" in
  help)
    exec "$venv_python" -m edge_lm_server.cli --help
    ;;
  run|menu|setup|clean|-h|--help)
    exec "$venv_python" -m edge_lm_server.cli "$@"
    ;;
  *)
    exec "$venv_python" -m edge_lm_server.cli menu "$@"
    ;;
esac
